      "created_by_ref": "identity--a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "HyperHives macOS Infostealer",
      "description": "Rust-compiled Mach-O universal binary (x86_64 + arm64) infostealer delivered via a fake job interview pipeline on Wellfound (AngelList). Operator persona 'Felix' from 'HyperHive' directed targets to visit hyperhives.net and check 'Settings > Diagnostics > Log', triggering curl | bash execution from macos.hyperhives.net. Variant internally labelled 'pussy stealer'. Build codename 'force', version 9.12.1. Targets browser credentials, crypto wallets (276 extension IDs), password managers, macOS Keychain, Apple Notes, and Telegram sessions. Uses Sentry SDK for operational telemetry.",
      "malware_types": ["spyware", "trojan"],
      "is_family": false,
      "first_seen": "2026-04-06T00:00:00.000Z",
      "architecture_execution_envs": ["x86-64", "arm64"],
      "implementation_languages": ["Rust"],
      "operating_system_refs": ["identity--apple-macos"],
      "capabilities": [
        "accesses-remote-machines",
        "captures-input-peripherals",
        "exfiltrates-data",
        "steals-authentication-credentials"
      ],
      "sample_refs": ["malware-analysis--sample-sha256"]
    },
